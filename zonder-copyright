    <button class="schaal-knop" onclick="scegliScala(this,'mano pollice-mignolo ca. 20 cm')">&#9995; Mano</button>
    <button class="schaal-knop" onclick="scegliScalaPiede(this)">&#128095; Piede</button>
    <button class="schaal-knop" onclick="scegliScala(this,'nessun riferimento')">&#10005; Nessuno</button>
  </div>
  <input type="text" class="extra-inp" id="riferimentoScala" placeholder="o digita es. taglia 43 / bottiglia 20 cm...">
  <div class="camera-container">
