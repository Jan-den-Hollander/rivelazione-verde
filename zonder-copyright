  if(!win){mostraNot('Popup bloccato \u2014 consenti i popup');return;}
  win.document.write(
    '<!DOCTYPE html><html lang="it"><head>'+
    '<meta charset="UTF-8"><title>RivelazioneVerde Mappa \u2014 '+nome+'</title>'+
    '<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>'+
    '<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"><\/script>'+
    '<style>'+css+'</style></head><body>'+
    '<h1>RivelazioneVerde \u2014 '+nome+'</h1>'+
    '<div class="meta">'+metaHtml+'</div>'+
    '<div id="mappaPrint"></div>'+
    '<div class="legenda">'+
    '<div class="li"><div class="lp" style="background:#1a5a7a"></div> Non analizzato</div>'+
    '<div class="li"><div class="lp" style="background:#e8a020"></div> Analizzato, in attesa</div>'+
    '<div class="li"><div class="lp" style="background:#3a7d34"></div> Pronto &amp; esportato</div>'+
    '</div>'+
    '<script>'+
    'window.onload=function(){'+
    '  var qs='+gpsData+';'+
    '  var k=L.map("mappaPrint",{zoomControl:false,attributionControl:false});'+
    '  L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png",{maxZoom:19}).addTo(k);'+
    '  var coords=[];'+
    '  qs.forEach(function(q){'+
    '    var pts=q.gps.split(","),lat=parseFloat(pts[0]),lon=parseFloat(pts[1]);'+
    '    if(!isNaN(lat)&&!isNaN(lon)){'+
    '      coords.push([lat,lon]);'+
    '      var kl=q.esportato?"#3a7d34":(q.analisi?"#e8a020":"#1a5a7a");'+
    '      var rand=q.esportato?"#7dcf75":(q.analisi?"#f5c842":"#70c8e8");'+
    '      var ic=L.divIcon({className:"",html:"<div style=\\"background:"+kl+";color:#fff;border:2px solid "+rand+";border-radius:50%;width:32px;height:32px;display:flex;align-items:center;justify-content:center;font-family:monospace;font-size:11px;font-weight:700;box-shadow:0 2px 6px rgba(0,0,0,.5)\\">"+q.nr+"</div>",iconSize:[32,32],iconAnchor:[16,16]});'+
    '      L.marker([lat,lon],{icon:ic}).addTo(k).bindTooltip(q.nr.toString());'+
    '    }'+
    '  });'+
    '  if(coords.length===1)k.setView(coords[0],17);'+
    '  else if(coords.length>1)k.fitBounds(L.latLngBounds(coords),{padding:[30,30]});'+
    '  setTimeout(function(){k.invalidateSize();},300);'+
    '  setTimeout(function(){window.print();},1200);'+
    '};'+
    '<\/script>'+
    '</body></html>'
  );
  win.document.close();
}

function esportaCSV(){
  if(!stato.quadrati.length){mostraNot('Nessun dato');return;}
  var loc=stato.rilievo?stato.rilievo.localita:'',rd=stato.rilievo?stato.rilievo.data:'';
  var righe=[['Operatore','Localita','Data rilievo','Quadrato nr','Data','Ora','GPS lat','GPS lon','Regione/tipo','Riferimento scala','Nome scientifico','Nome italiano','Copertura %','Abbondanza','Affidabilita','Certezza %','Domanda botanico','Analizzato con','Impressione generale','Contesto fitosociologico']];
  var op=stato.rilievo?stato.rilievo.operatore||'':'';
  stato.quadrati.forEach(function(q){
    var dt=q.timestamp?q.timestamp.split('T'):['',''];
    var la='',lo='';
    if(q.gps&&q.gps.indexOf(',')!==-1){var gp=q.gps.split(',');la=gp[0].trim();lo=gp[1].trim();}
    var ai=q.analisiAI||'',imp='',fyto='';
    if(q.analisi&&!q.analisi.testoLibero&&(q.analisi.specie||[]).length){
      imp=q.analisi.osservazioni||'';fyto=q.analisi.fitosociologia||'';
      q.analisi.specie.forEach(function(s){righe.push([op,loc,rd,q.nr,dt[0],dt[1]?dt[1].substring(0,5):'',la,lo,q.regione||'',q.scala||'',s.scientifico||'',s.italiano||s.nl||'',s.copertura!=null?s.copertura:'',s.abbondanza||'',s.affidabilita||'',s.certezza!=null?s.certezza:'',s.domanda||'',ai,imp,fyto]);});
    } else if(q.analisi&&q.analisi.testoLibero){
      righe.push([op,loc,rd,q.nr,dt[0],dt[1]?dt[1].substring(0,5):'',la,lo,q.regione||'',q.scala||'','','','','','','','',ai,q.analisi.osservazioni||'','']);
    } else {
      righe.push([op,loc,rd,q.nr,dt[0],dt[1]?dt[1].substring(0,5):'',la,lo,q.regione||'',q.scala||'','','','','','non analizzato','','','','','']);
    }
    righe.push(new Array(20).fill(''));
  });
  var csv=righe.map(function(r){return r.map(function(c){return '"'+(c+'').replace(/"/g,'""')+'"';}).join(',');}).join('\n');
  var a=document.createElement('a');
  a.href=URL.createObjectURL(new Blob(['\uFEFF'+csv],{type:'text/csv;charset=utf-8'}));
  a.download='rivelazioneVerde_'+(stato.rilievo?stato.rilievo.data+'_'+stato.rilievo.localita.substring(0,15).replace(/\s/g,'_'):'export')+'.csv';
  a.click();mostraNot('CSV scaricato \u2713');marcaEsportato();
}

function esportaDubbi(){
  if(!stato.quadrati.length){mostraNot('Nessun dato');return;}
  var r=['LISTA DUBBI - RivelazioneVerde\n'];
  if(stato.rilievo)r.push('Localit\u00e0: '+stato.rilievo.localita+'\nData: '+stato.rilievo.data+'\n\n');
  var ht=false;
  stato.quadrati.forEach(function(q){
    if(!q.analisi)return;
    if(q.analisi.testoLibero){r.push('Q'+q.nr+' ['+(q.analisiAI||'AI')+'] (testo libero)\n');return;}
    var dub=(q.analisi.specie||[]).filter(function(s){return s.affidabilita!=='certo';});
    if(!dub.length)return;ht=true;
    r.push('QUADRATO '+q.nr+' ['+(q.analisiAI||'AI')+'] '+(q.regione?'['+q.regione+'] ':'')+q.gps);
    if(q.scala)r.push('  Scala: '+q.scala);
    dub.forEach(function(s){r.push('  * '+(s.italiano||s.scientifico)+' ('+(s.scientifico||'?')+') ['+s.affidabilita+(s.certezza!=null?' / '+s.certezza+'%':'')+']');if(s.domanda)r.push('    Domanda: '+s.domanda);});
    if(q.analisi.osservazioni)r.push('  Impressione: '+q.analisi.osservazioni);
    if(q.analisi.fitosociologia)r.push('  Fitosoc.: '+q.analisi.fitosociologia);
    r.push('');
  });
  if(!ht){mostraNot('Nessun dubbio \u2713');return;}
  var a=document.createElement('a');
  a.href=URL.createObjectURL(new Blob([r.join('\n')],{type:'text/plain;charset=utf-8'}));
  a.download='lista_dubbi_'+(stato.rilievo?stato.rilievo.data:'export')+'.txt';
  a.click();mostraNot('Lista dubbi scaricata');
}

function salvaStato(){
  try{
    localStorage.setItem('rv_rilievo',JSON.stringify(stato.rilievo));
    var m=stato.quadrati.map(function(q,i){return{nr:q.nr,timestamp:q.timestamp,gps:q.gps,scala:q.scala||'',regione:q.regione||'',analisi:q.analisi,analisiGrezzo:q.analisiGrezzo||'',analisiAI:q.analisiAI||'',esportato:q.esportato||false,foto:q.foto?'presente':null};});
    localStorage.setItem('rv_quadrati_meta',JSON.stringify(m));
    stato.quadrati.forEach(function(q,i){if(q.foto)try{localStorage.setItem('rv_foto_'+i,q.foto);}catch(e){}});
  }catch(e){}
}

function caricaDatiSalvati(){
  try{
    var r=localStorage.getItem('rv_rilievo'),pm=localStorage.getItem('rv_quadrati_meta');
    if(r){stato.rilievo=JSON.parse(r);if(stato.rilievo){
      document.getElementById('localitaNome').value=stato.rilievo.localita||'';
      document.getElementById('dataInput').value=stato.rilievo.data||'';
      document.getElementById('gpsDisplay').textContent=stato.rilievo.gps||'Non ancora determinato';
      document.getElementById('numQuadrati').value=stato.rilievo.numQuadrati||10;
      document.getElementById('rondaLabel').textContent=stato.rilievo.localita.substring(0,22);
      if(stato.rilievo.operatore)document.getElementById('operatore').value=stato.rilievo.operatore;
    }}
    if(pm){stato.quadrati=JSON.parse(pm).map(function(q,i){if(q.foto==='presente')q.foto=localStorage.getItem('rv_foto_'+i)||null;return q;});}
    aggiornaContatoreQuadrato();
  }catch(e){}
}

function aggiornaPanoramica(){
  var s={},o=0;
  stato.quadrati.forEach(function(q){if(!q.analisi||q.analisi.testoLibero)return;(q.analisi.specie||[]).forEach(function(x){s[x.scientifico||x.italiano]=true;if(x.affidabilita!=='certo')o++;});});
  document.getElementById('totaleSpecie').textContent=Object.keys(s).length;
  document.getElementById('totaleQuadrati').textContent=stato.quadrati.length;
  document.getElementById('totaleIncerti').textContent=o;
  disegnaCarta();
  var l='';
  stato.quadrati.forEach(function(q){
    var st=q.analisi?(q.analisi.testoLibero?'Analisi presente':(q.analisi.specie||[]).slice(0,3).map(function(x){return x.italiano||x.scientifico;}).join(', ')):'In attesa di analisi';
    var oz=(!q.analisi||q.analisi.testoLibero)?0:(q.analisi.specie||[]).filter(function(x){return x.affidabilita!=='certo';}).length;
    l+='<div class="plot-elemento">';
    if(q.foto)l+='<img class="plot-thumb" src="'+q.foto+'" alt="Q'+q.nr+'">';
    else l+='<div class="plot-thumb-placeholder">&#127807;</div>';
    l+='<div class="plot-info"><div class="plot-nr">Q'+q.nr;
    if(q.analisiAI)l+=' &mdash; <span style="color:#70c8e8;font-size:.55rem">'+esc(q.analisiAI)+'</span>';
    l+='</div>';
    if(q.regione)l+='<div style="font-size:.6rem;color:#6a9465;margin-bottom:2px">'+esc(q.regione)+'</div>';
    l+='<div class="plot-specie">'+esc(st)+'</div>';
    l+='<div class="plot-badges">';
    if(!q.analisi)l+='<span class="badge badge-attesa">attesa</span>';
    if(oz>0)l+='<span class="badge badge-incerto">&#9888; '+oz+' da verificare</span>';
    if(q.gps&&q.gps!=='Non ancora determinato')l+='<span class="badge badge-gps">GPS</span>';
    l+='</div></div></div>';
  });
  document.getElementById('listaQuadrati').innerHTML=l||'<div style="font-size:.75rem;color:#6a9465;text-align:center;padding:20px">Nessun quadrato</div>';
}

function aggiornaSchermoExport(){
  var el=document.getElementById('archivioRilievi');
  if(stato.rilievo){var g=stato.quadrati.filter(function(q){return q.analisi;}).length;el.innerHTML='<div style="color:var(--bianco);margin-bottom:4px">'+esc(stato.rilievo.localita)+'</div><div>'+stato.rilievo.data+' &mdash; '+stato.quadrati.length+' quadrati, '+g+' analizzati</div>';}
  else el.textContent='Nessun rilievo attivo';
}

function marcaEsportato(){stato.quadrati.forEach(function(q){if(q.analisi)q.esportato=true;});salvaStato();}

function eliminaRilievo(){
  if(!confirm('Eliminare il rilievo? Esporta prima i dati!'))return;
  stato.rilievo=null;stato.quadrati=[];
  localStorage.removeItem('rv_rilievo');localStorage.removeItem('rv_quadrati_meta');
  document.getElementById('rondaLabel').textContent='Nessun rilievo';
  aggiornaPanoramica();mostraNot('Rilievo eliminato');
}

function mostraNot(t){var n=document.getElementById('notif');n.textContent=t;n.classList.add('visibile');setTimeout(function(){n.classList.remove('visibile');},2400);}
</script>
