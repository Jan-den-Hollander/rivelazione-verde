<script>
var stato={rilievo:null,quadrati:[],stream:null,fotoCorrente:null};

var PROMPT_BASE='Begin your response with a short introduction line:\n"Analysis by: [your name and version, e.g. Gemini 2.0 Flash / Claude Sonnet 4 / Le Chat Mistral Large]"\n\nYou are an expert botanical field assistant. Analyze this photo of a vegetation plot of exactly 1 m\u00b2.\n\nLocation/region: [REGIONE]\nScale reference visible in photo: [SCALA]\n\nIMPORTANT ITALIAN CONTEXT: Italy has highly diverse vegetation zones. Adapt phytosociological expectations based on the region:\n- Mediterranean south & islands: macchia, garrigue, Quercus ilex, Pistacia, Cistus\n- Po plain & Adriatic: continental grasslands, hygrophilous and ruderal species\n- Alpine/Pre-alpine north: alpine meadows, Carex, Gentiana, Dryas, Sesleria\n- Apennine belt: mixed deciduous, calcareous grasslands\n- Coastal dunes & wetlands: halophytes, psammophytes\n- Urban verges: cosmopolitan ruderal flora\n\nPerform a quadrat analysis by mentally dividing the photo into segments.\n\nProvide a structured list per species:\n\u2022 Scientific name\n\u2022 Italian common name\n\u2022 Estimated cover percentage (%)\n\u2022 Abundance (rare / scarce / frequent / abundant / dominant)\n\u2022 Reliability (0-100% certainty)\n\u2022 Optional determination question for the botanist\n\nGeneral assessment: describe (1) vegetation structure, (2) nutrient/substrate status, (3) phytosociological context (Italian alliance/association).\nAnswer in Italian.';

function getPromptPerQuadrato(q){
  var r=(q&&q.regione)||document.getElementById('regioneHint').value.trim()||'non specificata';
  var s=(q&&q.scala)||document.getElementById('riferimentoScala').value.trim()||'nessun riferimento';
  return PROMPT_BASE.replace('[REGIONE]',r).replace('[SCALA]',s);
}

function scegliScala(k,v){document.querySelectorAll('.schaal-knop').forEach(function(x){x.classList.remove('actief');});k.classList.add('actief');document.getElementById('riferimentoScala').value=v;}
function scegliScalaPiede(k){var t=prompt('Taglia scarpe?','43');if(t){document.querySelectorAll('.schaal-knop').forEach(function(x){x.classList.remove('actief');});k.classList.add('actief');document.getElementById('riferimentoScala').value='piede taglia '+t;}}
function apriModal(){document.getElementById('consigliFotoModal').classList.add('open');}
function chiudiModalDiretto(){document.getElementById('consigliFotoModal').classList.remove('open');}
function chiudiModal(e){if(e.target===document.getElementById('consigliFotoModal'))chiudiModalDiretto();}

window.addEventListener('load',function(){
  document.getElementById('dataInput').value=new Date().toISOString().split('T')[0];
  caricaDatiSalvati();aggiornaPanoramica();aggiornaListaCampo();costruisciListaAnalisi();
  verificaCopyright();
});

function verificaCopyright(){
  var src=document.documentElement.outerHTML;
  var impr=['Legge 633/1941','Convenzione di Berna','Copyright (c) 2025','RivelazioneVerde'];
  if(!impr.every(function(t){return src.indexOf(t)!==-1;}))mostraAvvisoCopyright();
}
function mostraAvvisoCopyright(){
  var ts=new Date().toISOString();
  var o=document.createElement('div');o.className='cr-overlay';
  o.innerHTML='<div class="cr-box"><div class="cr-titolo">&#9888;&#65039; Avviso sul diritto d\'autore</div><div class="cr-testo">L\'indicazione del diritto d\'autore di <strong>RivelazioneVerde</strong> \u00e8 stata modificata o rimossa.<br><br>Protetto dalla <strong>Legge 633/1941</strong> e dalla <strong>Convenzione di Berna</strong>.</div><div class="cr-rif">Rif: RV-'+ts+'</div></div>';
  document.body.appendChild(o);
}

function mostraSchermo(nome){
  document.querySelectorAll('.screen').forEach(function(s){s.classList.remove('active');});
  document.querySelectorAll('.tab').forEach(function(t){t.classList.remove('active');});
  document.getElementById('schermo-'+nome).classList.add('active');
  var tabs=document.querySelectorAll('.tab');
  ['setup','camera','analisi','panoramica','mappa','export'].forEach(function(n,i){if(n===nome)tabs[i].classList.add('active');});
  if(nome==='camera'){avviaCamera();aggiornaListaCampo();}else fermaCamera();
  if(nome==='panoramica')aggiornaPanoramica();
  if(nome==='export')aggiornaSchermoExport();
  if(nome==='analisi')costruisciListaAnalisi();
  if(nome==='mappa')setTimeout(disegnaMappaTotale,100);
}

function iniziaRilievo(){
  var loc=document.getElementById('localitaNome').value.trim();
  if(!loc){mostraNot('Inserisci il nome della localit\u00e0');return;}
  if(!confirm('Iniziare un nuovo rilievo? I dati correnti saranno eliminati.'))return;
  stato.rilievo={id:Date.now(),localita:loc,data:document.getElementById('dataInput').value,gps:document.getElementById('gpsDisplay').textContent,numQuadrati:parseInt(document.getElementById('numQuadrati').value)||10,operatore:document.getElementById('operatore').value.trim()||'Sconosciuto'};
  stato.quadrati=[];salvaStato();
  document.getElementById('rondaLabel').textContent=loc.substring(0,22)+(loc.length>22?'...':'');
  aggiornaContatoreQuadrato();mostraSchermo('camera');mostraNot('Rilievo avviato');
}

function determinaGPS(){
  var d=document.getElementById('gpsDisplay'),k=document.getElementById('gpsBottone');
  d.textContent='Ricerca...';d.style.color='#e8a020';
  if(k){k.innerHTML='&#9203;';k.disabled=true;}
  if(!navigator.geolocation){d.textContent='GPS non disponibile';if(k){k.innerHTML='&#128205; GPS';k.disabled=false;}return;}
  navigator.geolocation.getCurrentPosition(
    function(pos){var c=pos.coords.latitude.toFixed(5)+', '+pos.coords.longitude.toFixed(5);d.textContent=c;d.style.color='#7dcf75';if(k){k.innerHTML='&#10003;';k.disabled=false;}if(stato.rilievo){stato.rilievo.gps=c;salvaStato();}mostraNot('GPS determinato \u2713');},
    function(err){d.style.color='#e87070';if(k){k.innerHTML='&#128205; GPS';k.disabled=false;}d.textContent=err.code===1?'Autorizzazione negata':err.code===2?'Segnale non trovato':'Timeout';mostraNot('GPS fallito');},
    {enableHighAccuracy:true,timeout:10000,maximumAge:0}
  );
}

function avviaCamera(){if(stato.stream)return;navigator.mediaDevices.getUserMedia({video:{facingMode:'environment',width:{ideal:1280},height:{ideal:960}}}).then(function(s){stato.stream=s;var v=document.getElementById('videoFeed');v.srcObject=s;v.style.display='block';document.getElementById('fotoAnteprima').style.display='none';document.getElementById('salvaBtn').style.display='none';stato.fotoCorrente=null;}).catch(function(e){mostraNot('Camera: '+e.message);});}
function fermaCamera(){if(stato.stream){stato.stream.getTracks().forEach(function(t){t.stop();});stato.stream=null;}}
function nuovaCamera(){fermaCamera();stato.fotoCorrente=null;document.getElementById('fotoAnteprima').style.display='none';document.getElementById('videoFeed').style.display='block';document.getElementById('salvaBtn').style.display='none';avviaCamera();}

function scattaFoto(){
  if(!stato.rilievo){mostraNot('Avvia prima un rilievo');return;}
  var v=document.getElementById('videoFeed'),c=document.getElementById('fotoCanvas');
  c.width=v.videoWidth||640;c.height=v.videoHeight||480;c.getContext('2d').drawImage(v,0,0);
  stato.fotoCorrente=c.toDataURL('image/jpeg',0.82);
  document.getElementById('fotoAnteprima').src=stato.fotoCorrente;
  document.getElementById('fotoAnteprima').style.display='block';
  document.getElementById('videoFeed').style.display='none';
  document.getElementById('salvaBtn').style.display='inline-flex';
}

function aggiornaContatoreQuadrato(){document.getElementById('contatoreQuadrato').textContent='Quadrato '+(stato.quadrati.length+1)+' / '+(stato.rilievo?stato.rilievo.numQuadrati:10);}

function salvaQuadrato(){
  if(!stato.fotoCorrente){mostraNot('Scatta prima una foto');return;}
  var scala=document.getElementById('riferimentoScala').value.trim()||'nessun riferimento';
  var regione=document.getElementById('regioneHint').value.trim()||'';
  navigator.geolocation.getCurrentPosition(
    function(pos){_salva(pos.coords.latitude.toFixed(5)+', '+pos.coords.longitude.toFixed(5),scala,regione);},
    function(){_salva(stato.rilievo?stato.rilievo.gps:'',scala,regione);},{timeout:3000}
  );
}
function _salva(gps,scala,regione){
  var q={nr:stato.quadrati.length+1,timestamp:new Date().toISOString(),gps:gps,scala:scala,regione:regione,foto:stato.fotoCorrente,analisi:null,analisiGrezzo:'',analisiAI:''};
  stato.quadrati.push(q);salvaStato();nuovaCamera();aggiornaContatoreQuadrato();aggiornaListaCampo();
  mostraNot('Quadrato '+q.nr+' salvato');
}

function aggiornaListaCampo(){
  var el=document.getElementById('listaQuadratiCampo');
  if(!stato.quadrati.length){el.innerHTML='<div style="color:#6a9465;padding:4px 0">Nessun quadrato ancora</div>';return;}
  var h='';
  stato.quadrati.forEach(function(q){
    h+='<div style="display:flex;align-items:center;gap:8px;padding:5px 0;border-bottom:1px solid var(--linea)">';
    h+='<span style="font-size:.65rem;color:#a8d4a0;min-width:70px">Q'+q.nr+'</span>';
    h+=q.analisi?'<span class="badge badge-certo">pronto</span>':'<span class="badge badge-attesa">attesa</span>';
    if(q.regione)h+='<span style="font-size:.55rem;color:#6a9465">'+esc(q.regione.substring(0,18))+'</span>';
    if(q.gps&&q.gps!=='Non ancora determinato')h+='<span class="badge badge-gps">GPS</span>';
    h+='</div>';
  });
  el.innerHTML=h;
}

function costruisciListaAnalisi(){
  var c=document.getElementById('listaAnalisi');if(!c)return;
  if(!stato.quadrati.length){c.innerHTML='<div style="font-size:.75rem;color:#6a9465;text-align:center;padding:20px">Nessun quadrato</div>';return;}
  var h='';
  stato.quadrati.forEach(function(q){
    h+='<div class="analisi-card" id="ac_'+q.nr+'">';
    h+='<div class="analisi-card-header"><div>';
    h+='<div class="label" style="margin:0">Quadrato '+q.nr+'</div>';
    h+='<div style="font-size:.6rem;color:#6a9465">'+(q.timestamp?q.timestamp.substring(0,10)+' '+q.timestamp.substring(11,16):'');
    if(q.gps&&q.gps!=='Non ancora determinato')h+=' &#128205; '+q.gps;
    h+='</div>';
    if(q.regione)h+='<div style="font-size:.58rem;color:#6a9465;margin-top:2px">&#127807; '+esc(q.regione)+'</div>';
    if(q.scala&&q.scala!=='nessun riferimento')h+='<div style="font-size:.58rem;color:#6a9465">&#128207; '+esc(q.scala)+'</div>';
    if(q.analisiAI)h+='<div class="ai-tag">&#129302; '+esc(q.analisiAI)+'</div>';
    h+='</div>';
    if(q.analisi)h+='<button class="btn-reset-analisi" onclick="resetAnalisi('+q.nr+')">&#8635; Ripeti</button>';
    h+='</div>';
    if(q.foto)h+='<img src="'+q.foto+'" class="analisi-foto">';
    h+='<div id="wf_'+q.nr+'" style="'+(q.analisi?'display:none':'')+'">';
    h+='<div class="passo-hint">Passo 1 &amp; 2: Condividi foto e copia prompt</div>';
    h+='<div class="passo-riga">';
    h+='<button class="btn btn-condividi" onclick="condividiFoto('+q.nr+')">&#8679; Condividi</button>';
    h+='<button class="btn btn-prompt" onclick="copiaPrompt('+q.nr+')">&#128203; Copia prompt</button>';
    h+='</div>';
    h+='<div class="passo-hint">Passo 3: Incolla la risposta dell\'AI qui sotto</div>';
    h+='<textarea class="risultato-input" id="ta_'+q.nr+'" placeholder="Incolla qui la risposta dell\'AI..."></textarea>';
    h+='<button class="btn btn-salva-analisi" onclick="salvaAnalisi('+q.nr+')">&#10003; Salva analisi</button>';
    h+='</div>';
    h+='<div id="res_'+q.nr+'" class="analisi-risultato">'+(q.analisi?risultatoHtml(q):'')+'</div>';
    h+='</div>';
  });
  c.innerHTML=h;
}

function condividiFoto(nr){
  var q=stato.quadrati.find(function(x){return x.nr===nr;});
  if(!q||!q.foto){mostraNot('Nessuna foto');return;}
  var arr=q.foto.split(','),mime=arr[0].match(/:(.*?);/)[1],bstr=atob(arr[1]),n=bstr.length,u=new Uint8Array(n);
  while(n--)u[n]=bstr.charCodeAt(n);
  var blob=new Blob([u],{type:'image/jpeg'});
  // Semplice nome file senza underscore per massima compatibilità Android
  var file=new File([blob],'q'+nr+'.jpg',{type:'image/jpeg'});
  var shareData={title:'Q'+nr,text:getPromptPerQuadrato(q),files:[file]};
  if(navigator.canShare&&navigator.canShare(shareData)){
    navigator.share(shareData)
      .then(function(){mostraNot('Condiviso \u2713');})
      .catch(function(e){
        if(e.name==='AbortError')return;
        // Fallback: prova solo con la foto, senza il testo del prompt
        _condividiSoloFoto(file,nr);
      });
  } else if(navigator.canShare&&navigator.canShare({files:[file]})){
    // Android rifiuta testo+file insieme — condividi solo la foto
    _condividiSoloFoto(file,nr);
  } else {
    // Fallback finale: scarica la foto
    var url=URL.createObjectURL(blob),a=document.createElement('a');
    a.href=url;a.download='q'+nr+'.jpg';a.click();
    mostraNot('Foto scaricata \u2014 aprila nell\'app AI');
  }
}

function _condividiSoloFoto(file,nr){
  navigator.share({files:[file]})
    .then(function(){
      mostraNot('Foto condivisa \u2713 \u2014 copia il prompt separatamente');
    })
    .catch(function(e){
      if(e.name!=='AbortError'){
        var url=URL.createObjectURL(file),a=document.createElement('a');
        a.href=url;a.download='q'+nr+'.jpg';a.click();
        mostraNot('Foto scaricata \u2014 aprila nell\'app AI');
      }
    });
}

function copiaPrompt(nr){
  var q=nr?stato.quadrati.find(function(x){return x.nr===nr;}):null;
  var p=getPromptPerQuadrato(q);
  if(navigator.clipboard&&navigator.clipboard.writeText){navigator.clipboard.writeText(p).then(function(){mostraNot('Prompt copiato \u2713');}).catch(function(){_copFb(p);});}
  else _copFb(p);
}
function _copFb(t){var x=document.createElement('textarea');x.value=t;x.style.position='fixed';x.style.opacity='0';document.body.appendChild(x);x.focus();x.select();try{document.execCommand('copy');mostraNot('Prompt copiato \u2713');}catch(e){mostraNot('Copia manualmente');}document.body.removeChild(x);}

function salvaAnalisi(nr){
  var q=stato.quadrati.find(function(x){return x.nr===nr;});if(!q)return;
  var ta=document.getElementById('ta_'+nr);
  if(!ta||!ta.value.trim()){mostraNot('Incolla prima la risposta AI');return;}
  q.analisiGrezzo=ta.value.trim();
  var m=(q.analisiGrezzo.split('\n')[0]||'').match(/Analysis by:\s*(.+)/i);
  q.analisiAI=m?m[1].trim():'AI';
  var t=q.analisiGrezzo,s=t.indexOf('{'),e=t.lastIndexOf('}');
  if(s!==-1&&e>s){try{q.analisi=JSON.parse(t.substring(s,e+1));}catch(x){q.analisi=testo(t);}}
  else q.analisi=testo(t);
  salvaStato();
  var wf=document.getElementById('wf_'+nr),res=document.getElementById('res_'+nr);
  if(wf)wf.style.display='none';
  if(res)res.innerHTML=risultatoHtml(q);
  var ac=document.getElementById('ac_'+nr);
  var tag=ac.querySelector('.ai-tag');
  if(tag)tag.innerHTML='&#129302; '+esc(q.analisiAI);
  else{var d=document.createElement('div');d.className='ai-tag';d.innerHTML='&#129302; '+esc(q.analisiAI);ac.querySelector('.analisi-card-header div').appendChild(d);}
  if(!ac.querySelector('.btn-reset-analisi')){var b=document.createElement('button');b.className='btn-reset-analisi';b.innerHTML='&#8635; Ripeti';b.onclick=function(){resetAnalisi(nr);};ac.querySelector('.analisi-card-header').appendChild(b);}
  aggiornaListaCampo();aggiornaPanoramica();mostraNot('Quadrato '+nr+' salvato \u2713');
}

function testo(t){return{specie:[],osservazioni:t,testoLibero:true};}
function resetAnalisi(nr){var q=stato.quadrati.find(function(x){return x.nr===nr;});if(!q)return;q.analisi=null;q.analisiGrezzo='';salvaStato();costruisciListaAnalisi();mostraNot('Analisi eliminata');}

function risultatoHtml(q){
  if(!q.analisi)return '';
  var h='';
  if(q.analisiAI)h+='<div class="ai-tag">&#129302; '+esc(q.analisiAI)+'</div>';
  if(q.analisi.testoLibero){
    h+='<div style="background:#0f1f0d;border-left:3px solid var(--verdechiaro);padding:12px;border-radius:0 3px 3px 0;margin-top:4px">';
    h+='<div class="label" style="margin-bottom:6px">Analisi AI</div>';
    h+='<div style="font-size:.72rem;line-height:1.8;white-space:pre-wrap;color:var(--bianco)">'+esc(q.analisi.osservazioni)+'</div></div>';
  } else {
    (q.analisi.specie||[]).forEach(function(s){
      var kl=s.affidabilita==='certo'?'':(s.affidabilita==='incerto'?' incerto':' sconosciuto');
      var bd=s.affidabilita==='certo'?'badge-certo':(s.affidabilita==='incerto'?'badge-incerto':'badge-sconosciuto');
      h+='<div class="specie-card'+kl+'"><div class="specie-nome">'+(s.scientifico||'\u2014')+'</div>';
      h+='<div class="specie-it">'+(s.italiano||s.nl||'')+'</div>';
      h+='<div class="specie-meta"><span class="badge '+bd+'">'+(s.affidabilita||'')+'</span>';
      h+='<span class="abbondanza">'+(s.abbondanza||'')+'</span>';
      if(s.copertura!=null)h+='<span class="copertura-chip">&#9608; '+s.copertura+'%</span>';
      if(s.certezza!=null)h+='<span class="affidabilita-chip">&#10003; '+s.certezza+'%</span>';
      h+='</div>';
      if(s.domanda)h+='<div class="domanda-ai">'+esc(s.domanda)+'</div>';
      h+='</div>';
    });
    if(q.analisi.osservazioni)h+='<div style="font-size:.68rem;color:#6a9465;font-style:italic;margin-top:4px;padding:6px;background:#0f1f0d;border-radius:2px">&#128172; '+esc(q.analisi.osservazioni)+'</div>';
    if(q.analisi.fitosociologia)h+='<div class="fyto-blocco"><div class="fyto-label">Contesto fitosociologico</div>'+esc(q.analisi.fitosociologia)+'</div>';
  }
  return h;
