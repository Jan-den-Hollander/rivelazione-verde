var cartaObj=null;
function disegnaCarta(){
  if(cartaObj){cartaObj.remove();cartaObj=null;}
  var c=document.getElementById('cartaContainer');if(!c)return;
  var gps=stato.quadrati.filter(function(q){return q.gps&&q.gps!=='Non ancora determinato'&&q.gps.indexOf(',')!==-1;});
  if(!gps.length){c.innerHTML='<div class="carta-nessuna"><div>&#128506;<br>Nessuna coordinata GPS</div></div>';return;}
  c.innerHTML='';c.style.height='260px';
  if(typeof L==='undefined'){c.innerHTML='<div class="carta-nessuna"><div>&#9888; Mappa non disponibile</div></div>';return;}
  cartaObj=L.map(c,{zoomControl:true});
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{maxZoom:19,attribution:'\u00a9 OpenStreetMap',crossOrigin:true}).addTo(cartaObj);
  var coords=[];
  gps.forEach(function(q){
    var pts=q.gps.split(','),lat=parseFloat(pts[0].trim()),lon=parseFloat(pts[1].trim());
    if(isNaN(lat)||isNaN(lon))return;coords.push([lat,lon]);
    var kl=q.analisi?'#3a7d34':'#1a5a7a';
    var ic=L.divIcon({className:'',html:'<div style="background:'+kl+';color:#fff;border:2px solid #fff;border-radius:50%;width:30px;height:30px;display:flex;align-items:center;justify-content:center;font-family:monospace;font-size:11px;font-weight:700;box-shadow:0 2px 8px rgba(0,0,0,.5)">Q'+q.nr+'</div>',iconSize:[30,30],iconAnchor:[15,15],popupAnchor:[0,-18]});
    var st=q.analisi?(q.analisi.testoLibero?'Analisi presente':(q.analisi.specie||[]).slice(0,3).map(function(s){return s.italiano||s.scientifico;}).join(', ')):'In attesa';
    L.marker([lat,lon],{icon:ic}).addTo(cartaObj).bindPopup('<b>Q'+q.nr+'</b><br>'+(q.regione?q.regione+'<br>':'')+(q.timestamp?q.timestamp.substring(0,16).replace('T',' '):'')+'<br>'+st);
  });
  if(coords.length===1)cartaObj.setView(coords[0],18);
  else if(coords.length>1)cartaObj.fitBounds(L.latLngBounds(coords),{padding:[40,40],maxZoom:18});
  setTimeout(function(){if(cartaObj)cartaObj.invalidateSize();},200);
}

