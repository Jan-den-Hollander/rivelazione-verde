<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>RivelazioneVerde</title>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<style>
  @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=Fraunces:ital,wght@0,300;0,600;1,300&display=swap');
  :root{--verde:#2d5a27;--verdechiaro:#4a7c42;--terra:#8b6f47;--bianco:#f5f2eb;--scuro:#1a2e17;--incerto:#e8a020;--certo:#3a7d34;--sconosciuto:#8b4444;--linea:rgba(45,90,39,0.2);}
  *{box-sizing:border-box;margin:0;padding:0;}
  body{font-family:'IBM Plex Mono',monospace;background:var(--scuro);color:var(--bianco);min-height:100vh;overflow-x:hidden;}
  .header{background:var(--verde);padding:12px 16px;display:flex;align-items:center;justify-content:space-between;border-bottom:2px solid var(--verdechiaro);position:sticky;top:0;z-index:100;}
  .header-title{font-family:'Fraunces',serif;font-size:1.2rem;font-weight:600;}
  .header-title span{font-style:italic;font-weight:300;color:#a8d4a0;}
  .ronda-badge{font-size:.6rem;background:var(--scuro);color:#a8d4a0;padding:4px 8px;border-radius:2px;letter-spacing:.1em;text-transform:uppercase;max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
  .tabs{display:flex;background:#0f1f0d;border-bottom:1px solid var(--linea);}
  .tab{flex:1;padding:8px 1px;text-align:center;font-size:.42rem;letter-spacing:.02em;text-transform:uppercase;color:#6a9465;cursor:pointer;border:none;background:none;transition:all .2s;line-height:1.3;}
  .tab.active{color:var(--bianco);background:var(--verde);border-bottom:2px solid #a8d4a0;}
  .cr-overlay{position:fixed;inset:0;background:rgba(0,0,0,.85);z-index:9999;display:flex;align-items:flex-end;justify-content:center;}
  .cr-box{background:#2a0a0a;border:2px solid #e87070;border-radius:8px 8px 0 0;width:100%;max-width:520px;padding:22px 18px 36px;}
  .cr-titolo{font-family:'Fraunces',serif;font-size:1.1rem;color:#e87070;margin-bottom:10px;}
  .cr-testo{font-size:.72rem;color:#f5d0d0;line-height:1.8;}
  .cr-rif{font-size:.62rem;color:#8a4a4a;margin-top:10px;font-style:italic;}
  .mappa-nome-bar{display:flex;gap:8px;align-items:center;margin-bottom:10px;}
  .mappa-nome-inp{flex:1;background:#0f1f0d;border:1px solid var(--linea);color:var(--bianco);padding:8px 10px;font-family:'IBM Plex Mono',monospace;font-size:.72rem;border-radius:2px;}
  .mappa-nome-inp:focus{outline:none;border-color:var(--verdechiaro);}
  .btn-mappa-refresh{background:#1e3a1a;border:1px solid var(--linea);color:#a8d4a0;padding:8px 10px;border-radius:2px;cursor:pointer;font-size:.9rem;flex-shrink:0;}
  #mappaTotaleContainer{height:calc(100vh - 280px);min-height:320px;border-radius:4px;overflow:hidden;border:1px solid var(--linea);margin-bottom:10px;}
  .mappa-legenda{display:flex;gap:12px;flex-wrap:wrap;font-size:.62rem;color:#a8d4a0;padding:8px 10px;background:#0f1f0d;border-radius:3px;margin-bottom:10px;}
  .legenda-punto{width:12px;height:12px;border-radius:50%;border:2px solid rgba(255,255,255,.4);flex-shrink:0;display:inline-block;}
  .btn-mappa-stampa{display:flex;align-items:center;justify-content:center;gap:8px;width:100%;background:#1a2a4a;color:#a0c8f0;border:1px solid #2a4a7a;padding:12px;font-family:'IBM Plex Mono',monospace;font-size:.75rem;letter-spacing:.06em;cursor:pointer;border-radius:2px;text-transform:uppercase;margin-bottom:8px;}
  .screen{display:none;padding:16px;}
  .screen.active{display:block;}
  .card{background:#1e3a1a;border:1px solid var(--linea);border-radius:4px;padding:16px;margin-bottom:12px;}
  .label{font-size:.6rem;letter-spacing:.12em;text-transform:uppercase;color:#a8d4a0;margin-bottom:6px;}
  .inp{width:100%;background:#0f1f0d;border:1px solid var(--linea);color:var(--bianco);padding:10px 12px;font-family:'IBM Plex Mono',monospace;font-size:.85rem;border-radius:2px;margin-bottom:10px;}
  .inp:focus{outline:none;border-color:var(--verdechiaro);}
  .gps-row{display:flex;gap:8px;align-items:center;}
  .gps-display{flex:1;background:#0f1f0d;border:1px solid var(--linea);padding:8px 12px;font-size:.7rem;color:#6a9465;border-radius:2px;font-family:'IBM Plex Mono',monospace;}
  .btn{display:inline-flex;align-items:center;justify-content:center;gap:6px;padding:10px 16px;font-family:'IBM Plex Mono',monospace;font-size:.75rem;letter-spacing:.06em;border:none;border-radius:2px;cursor:pointer;transition:all .15s;text-transform:uppercase;}
  .btn-primario{background:var(--verde);color:var(--bianco);width:100%;padding:14px;font-size:.8rem;}
  .btn-primario:active{background:var(--verdechiaro);transform:scale(.98);}
  .btn-camera{background:var(--verde);color:var(--bianco);border-radius:50%;width:72px;height:72px;font-size:1.8rem;flex-shrink:0;box-shadow:0 0 0 4px #1e3a1a,0 0 0 6px var(--verde);}
  .btn-camera:active{transform:scale(.93);}
  .btn-piccolo{background:#1e3a1a;color:#a8d4a0;border:1px solid var(--linea);font-size:.65rem;padding:7px 14px;}
  .btn-gps{background:var(--terra);color:var(--bianco);font-size:.65rem;padding:8px 12px;flex-shrink:0;}
  .btn-pericolo{background:#4a1a1a;color:#e87070;border:1px solid #6a2a2a;}
  .btn-condividi{background:#1a3a50;color:#70c8e8;border:1px solid #2a5a70;font-size:.7rem;padding:9px 14px;flex:1;}
  .btn-prompt{background:#2a1f00;color:#e8c070;border:1px solid #5a3f00;font-size:.7rem;padding:9px 14px;flex:1;}
  .btn-salva-analisi{background:var(--verde);color:var(--bianco);font-size:.7rem;padding:9px 14px;width:100%;margin-top:6px;}
  .btn-reset-analisi{background:#1e3a1a;color:#a8d4a0;border:1px solid var(--linea);font-size:.6rem;padding:5px 10px;border-radius:2px;cursor:pointer;}
  .btn-pdf{background:#1a2a4a;color:#a0c8f0;border:1px solid #2a4a7a;font-size:.75rem;padding:12px;width:100%;font-family:'IBM Plex Mono',monospace;cursor:pointer;border-radius:2px;letter-spacing:.06em;text-transform:uppercase;}
  .btn-fotoconsig{display:flex;align-items:center;gap:8px;width:100%;background:#1a3a16;border:1px solid #4a8a42;color:#a8d4a0;border-radius:4px;padding:10px 14px;font-family:'IBM Plex Mono',monospace;font-size:.75rem;cursor:pointer;margin-bottom:10px;}
  .modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:500;display:flex;align-items:flex-end;justify-content:center;opacity:0;pointer-events:none;transition:opacity .2s;}
  .modal-overlay.open{opacity:1;pointer-events:all;}
  .modal-box{background:#1a2e17;border:1px solid var(--verdechiaro);border-radius:8px 8px 0 0;width:100%;max-width:520px;padding:20px 18px 0;transform:translateY(20px);transition:transform .25s;max-height:85vh;display:flex;flex-direction:column;}
  .modal-overlay.open .modal-box{transform:translateY(0);}
  .modal-contenuto{overflow-y:auto;-webkit-overflow-scrolling:touch;padding-bottom:16px;flex:1;}
  .modal-titolo{font-family:'Fraunces',serif;font-size:1rem;font-weight:600;color:#a8d4a0;margin-bottom:14px;display:flex;justify-content:space-between;align-items:center;flex-shrink:0;}
  .modal-chiudi{background:none;border:none;color:#6a9465;font-size:1.3rem;cursor:pointer;}
  .modal-footer{border-top:1px solid var(--linea);padding:12px 0 28px;flex-shrink:0;}
  .btn-torna-camera{display:flex;align-items:center;justify-content:center;gap:8px;width:100%;background:var(--verde);color:var(--bianco);border:none;border-radius:4px;padding:14px;font-family:'IBM Plex Mono',monospace;font-size:.8rem;cursor:pointer;}
  .consiglio{background:#0f1f0d;border-left:3px solid var(--verdechiaro);border-radius:0 3px 3px 0;padding:10px 13px;margin-bottom:10px;}
  .consiglio-titolo{font-size:.65rem;letter-spacing:.1em;text-transform:uppercase;color:#a8d4a0;margin-bottom:4px;}
  .consiglio-testo{font-size:.72rem;color:var(--bianco);line-height:1.65;}
  .extra-inp{width:100%;background:#0f1f0d;border:1px solid var(--linea);color:var(--bianco);padding:8px 10px;font-family:'IBM Plex Mono',monospace;font-size:.72rem;border-radius:2px;margin-bottom:10px;}
  .extra-inp:focus{outline:none;border-color:var(--verdechiaro);}
  .schaal-knoppen{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:8px;}
  .schaal-knop{background:#0f1f0d;border:1px solid var(--linea);color:#a8d4a0;padding:7px 10px;border-radius:3px;font-family:'IBM Plex Mono',monospace;font-size:.65rem;cursor:pointer;transition:all .15s;white-space:nowrap;}
  .schaal-knop.actief{background:var(--verde);border-color:var(--verdechiaro);color:var(--bianco);}
  .camera-container{position:relative;background:#000;border-radius:4px;overflow:hidden;margin-bottom:12px;aspect-ratio:4/3;}
  #videoFeed{width:100%;height:100%;object-fit:cover;}
  #fotoAnteprima{width:100%;height:100%;object-fit:cover;display:none;}
  .kader-overlay{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;pointer-events:none;}
  .kader-vierkant{width:75%;aspect-ratio:1;border:2px dashed rgba(168,212,160,.8);position:relative;box-shadow:0 0 0 2000px rgba(0,0,0,.35);}
  .kader-vierkant::before{content:'1 m\00b2';position:absolute;top:-22px;left:50%;transform:translateX(-50%);font-size:.65rem;color:#a8d4a0;background:rgba(0,0,0,.6);padding:2px 8px;border-radius:2px;}
  .hoek{position:absolute;width:16px;height:16px;border-color:#a8d4a0;border-style:solid;}
  .hoek-tl{top:-2px;left:-2px;border-width:3px 0 0 3px;}
  .hoek-tr{top:-2px;right:-2px;border-width:3px 3px 0 0;}
  .hoek-bl{bottom:-2px;left:-2px;border-width:0 0 3px 3px;}
  .hoek-br{bottom:-2px;right:-2px;border-width:0 3px 3px 0;}
  .contatore-plot{position:absolute;top:10px;left:10px;background:rgba(0,0,0,.7);color:#a8d4a0;font-size:.65rem;padding:4px 8px;border-radius:2px;}
  .camera-controlli{display:flex;align-items:center;justify-content:space-between;gap:12px;padding:8px 0;}
  .plot-elemento{background:#1e3a1a;border:1px solid var(--linea);border-radius:4px;padding:10px;margin-bottom:8px;display:flex;gap:10px;align-items:flex-start;}
  .plot-thumb{width:56px;height:56px;object-fit:cover;border-radius:2px;flex-shrink:0;border:1px solid var(--linea);}
  .plot-thumb-placeholder{width:56px;height:56px;background:#0f1f0d;border-radius:2px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:1.4rem;color:#2d5a27;}
  .plot-info{flex:1;min-width:0;}
  .plot-nr{font-size:.6rem;letter-spacing:.1em;text-transform:uppercase;color:#a8d4a0;margin-bottom:3px;}
  .plot-specie{font-size:.72rem;color:var(--bianco);line-height:1.4;}
  .plot-badges{display:flex;gap:4px;flex-wrap:wrap;margin-top:4px;}
  .badge{font-size:.55rem;padding:3px 7px;border-radius:2px;letter-spacing:.08em;text-transform:uppercase;font-weight:600;}
  .badge-certo{background:#1a4a16;color:#7dcf75;}
  .badge-incerto{background:#4a3000;color:#e8a020;}
  .badge-sconosciuto{background:#4a1a1a;color:#e87070;}
  .badge-attesa{background:#1a2a3a;color:#70c8e8;}
  .badge-gps{background:#0f1f0d;color:#6a9465;}
  .specie-card{background:#0f1f0d;border-left:3px solid var(--certo);padding:10px 12px;margin-bottom:6px;border-radius:0 2px 2px 0;}
  .specie-card.incerto{border-left-color:var(--incerto);}
  .specie-card.sconosciuto{border-left-color:var(--sconosciuto);}
  .specie-nome{font-family:'Fraunces',serif;font-style:italic;font-size:1rem;font-weight:300;margin-bottom:2px;}
  .specie-it{font-size:.7rem;color:#a8d4a0;margin-bottom:6px;}
  .specie-meta{display:flex;gap:8px;flex-wrap:wrap;align-items:center;}
  .abbondanza{font-size:.65rem;color:#6a9465;}
  .copertura-chip{font-size:.62rem;background:#1a3a1a;color:#7dcf75;border:1px solid #2d5a27;padding:2px 7px;border-radius:2px;}
  .affidabilita-chip{font-size:.62rem;background:#1a2a3a;color:#70c8e8;border:1px solid #2a5a70;padding:2px 7px;border-radius:2px;}
  .domanda-ai{background:#2a1f00;border:1px solid #5a3f00;border-radius:3px;padding:8px 10px;margin-top:8px;font-size:.72rem;color:#e8c070;line-height:1.5;}
  .fyto-blocco{background:#1a1a0f;border:1px solid #4a4a20;border-radius:3px;padding:10px 12px;margin-top:8px;font-size:.72rem;color:#d4d47a;line-height:1.6;}
  .fyto-label{font-size:.58rem;letter-spacing:.1em;text-transform:uppercase;color:#8a8a40;margin-bottom:4px;}
  .totale-bar{background:#0f1f0d;border:1px solid var(--linea);border-radius:4px;padding:12px 14px;display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;}
  .totale-numero{font-family:'Fraunces',serif;font-size:1.8rem;font-weight:600;color:var(--bianco);line-height:1;}
  #cartaContainer{height:260px;border-radius:4px;overflow:hidden;margin-bottom:12px;border:1px solid var(--linea);}
  .carta-nessuna{background:#1a2e17;height:260px;display:flex;align-items:center;justify-content:center;margin-bottom:12px;border:1px solid var(--linea);border-radius:4px;color:#6a9465;font-size:.75rem;text-align:center;}
  .leaflet-popup-content-wrapper{background:#1e3a1a !important;color:var(--bianco) !important;border:1px solid var(--linea);border-radius:4px !important;font-family:'IBM Plex Mono',monospace;font-size:.7rem;}
  .leaflet-popup-tip{background:#1e3a1a !important;}
  .export-card{background:#1e3a1a;border:1px solid var(--linea);border-radius:4px;padding:16px;margin-bottom:12px;text-align:center;}
  .export-desc{font-size:.7rem;color:#6a9465;line-height:1.6;margin-bottom:12px;}
  .notif{position:fixed;bottom:20px;left:50%;transform:translateX(-50%);background:var(--verde);color:var(--bianco);padding:10px 20px;border-radius:4px;font-size:.75rem;z-index:999;opacity:0;transition:opacity .3s;pointer-events:none;white-space:nowrap;}
  .notif.visibile{opacity:1;}
  .divisore{border:none;border-top:1px solid var(--linea);margin:14px 0;}
  .sezione-titolo{font-size:.6rem;letter-spacing:.12em;text-transform:uppercase;color:#6a9465;margin-bottom:10px;}
  canvas{display:none;}
  .campo-hint{background:#1a3a16;border:1px solid #3a6a34;border-radius:4px;padding:10px 14px;margin-bottom:12px;font-size:.7rem;color:#a8d4a0;line-height:1.6;}
  .analisi-card{background:#1e3a1a;border:1px solid var(--linea);border-radius:4px;padding:14px;margin-bottom:12px;}
  .analisi-card-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px;}
  .analisi-foto{width:100%;border-radius:3px;margin-bottom:10px;max-height:160px;object-fit:cover;}
  .passo-riga{display:flex;gap:8px;margin-bottom:8px;}
  .passo-hint{font-size:.65rem;color:#6a9465;line-height:1.5;margin-bottom:8px;padding:6px 8px;background:#0f1f0d;border-radius:3px;}
  .risultato-input{width:100%;background:#0f1f0d;border:1px solid #3a6a34;color:var(--bianco);padding:10px 12px;font-family:'IBM Plex Mono',monospace;font-size:.72rem;border-radius:2px;min-height:80px;resize:vertical;line-height:1.5;}
  .risultato-input:focus{outline:none;border-color:#a8d4a0;}
  .risultato-input::placeholder{color:#3a6a34;}
  .analisi-risultato{margin-top:8px;}
  .ai-tag{font-size:.58rem;background:#1a2a3a;color:#70c8e8;padding:2px 7px;border-radius:2px;letter-spacing:.06em;display:inline-block;margin-top:4px;}
  #schermo-pdf{display:none;}
</style>
</head>
<body>

<!-- MODAL CONSIGLI FOTO -->
<div class="modal-overlay" id="consigliFotoModal" onclick="chiudiModal(event)">
  <div class="modal-box">
    <div class="modal-titolo">
      <span>&#128247; Consigli per foto migliori</span>
      <button class="modal-chiudi" onclick="chiudiModalDiretto()">&#10005;</button>
    </div>
    <div class="modal-contenuto">
      <div class="consiglio">
        <div class="consiglio-titolo">&#128260; Punto di ripresa</div>
        <div class="consiglio-testo">Fotografa il più possibile dall'alto (vista nadir). Con angolazione obliqua le percentuali di copertura non sono accurate.</div>
      </div>
      <div class="consiglio">
        <div class="consiglio-titolo">&#128207; Oggetto di riferimento</div>
        <div class="consiglio-testo">Posiziona nel quadrato un oggetto di dimensioni note:<br><br>
          &#128208; Righello o metro a nastro <em>(più preciso)</em><br>
          &#128273; Mazzo di chiavi <em>(ca. 10-12 cm)</em><br>
          &#128095; Il tuo piede — indica la taglia<br>
          &#128179; Carta di credito o telefono<br>
          &#9995; Mano: pollice a mignolo &#8776; 18-22 cm
        </div>
      </div>
      <div class="consiglio">
        <div class="consiglio-titolo">&#9728;&#65039; Illuminazione</div>
        <div class="consiglio-testo">Evita ombre dure. Una giornata leggermente nuvolosa dà i colori più uniformi.</div>
      </div>
      <div class="consiglio">
        <div class="consiglio-titolo">&#127807; Contesto regionale</div>
        <div class="consiglio-testo">Indica la regione (es. "macchia mediterranea Sicilia", "prateria alpina Dolomiti"). L'AI adatta le aspettative fitosociologiche.</div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn-torna-camera" onclick="chiudiModalDiretto()">&#128247; Torna a fotografare</button>
    </div>
  </div>
</div>

<div class="header">
  <div class="header-title">Rivelazione<span>Verde</span></div>
  <div class="ronda-badge" id="rondaLabel">Nessun rilievo</div>
</div>
<div class="tabs">
  <button class="tab active" onclick="mostraSchermo('setup')">&#9881;<br>Inizio</button>
  <button class="tab" onclick="mostraSchermo('camera')">&#128247;<br>Campo</button>
  <button class="tab" onclick="mostraSchermo('analisi')">&#128300;<br>Analisi</button>
  <button class="tab" onclick="mostraSchermo('panoramica')">&#128203;<br>Rilievo</button>
  <button class="tab" onclick="mostraSchermo('mappa')">&#128506;<br>Mappa</button>
  <button class="tab" onclick="mostraSchermo('export')">&#8599;<br>Export</button>
</div>

<!-- INIZIO -->
<div id="schermo-setup" class="screen active">
  <div class="card">
    <div class="label">&#128100; Operatore di campo</div>
    <input type="text" class="inp" id="operatore" placeholder="Nome dell'operatore">
    <div class="label">Località / Transetto</div>
    <input type="text" class="inp" id="localitaNome" placeholder="es. Sentiero del Parco km 0-0.5">
    <div class="label">Data rilievo</div>
    <input type="date" class="inp" id="dataInput">
    <div class="label">Punto GPS di partenza</div>
    <div class="gps-row">
      <div class="gps-display" id="gpsDisplay">Non ancora determinato</div>
      <button class="btn btn-gps" id="gpsBottone" onclick="determinaGPS()">&#128205; GPS</button>
    </div>
  </div>
  <div class="card">
    <div class="label">Dimensione quadrato</div>
    <input type="text" class="inp" id="dimQuadrato" value="1 m2" readonly>
    <div class="label">Numero quadrati (obiettivo)</div>
    <input type="number" class="inp" id="numQuadrati" value="10" min="1" max="50">
  </div>
  <button class="btn btn-primario" onclick="iniziaRilievo()">&#9654; Inizia nuovo rilievo</button>
  <hr class="divisore">
  <div class="sezione-titolo">Come si usa</div>
  <div class="campo-hint" style="background:#0f1f0d;border-color:var(--linea)">
    <strong>1. Inizio</strong> &#8594; località, GPS, avvia rilievo<br>
    <strong>2. Campo</strong> &#8594; foto per quadrato, regione e riferimento<br>
    <strong>3. Analisi</strong> &#8594; condividi foto con AI, incolla risposta<br>
    <strong>4. Rilievo</strong> &#8594; panoramica quadrati<br>
    <strong>5. Mappa</strong> &#8594; tutti i quadrati su mappa<br>
    <strong>6. Export</strong> &#8594; CSV o PDF con mappa per il botanico
  </div>
</div>

<!-- CAMPO -->
<div id="schermo-camera" class="screen">
  <button class="btn-fotoconsig" onclick="apriModal()">
    <span style="font-size:1.3rem">&#128247;</span>
    <span style="flex:1;text-align:left"><strong>Consigli per foto migliori</strong><br>
    <span style="font-size:.65rem;color:#6a9465">nadir &middot; riferimento &middot; regione &middot; luce</span></span>
    <span style="color:#4a8a42">&#8250;</span>
  </button>
  <div class="campo-hint">Fotografa ogni quadrato da 1m&#178;. Inserisci regione e riferimento.</div>
  <div class="label">&#127807; Regione / tipo di vegetazione</div>
